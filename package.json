{
  "name": "medical-image-classifier-root",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "concurrently --names \"BACKEND,FRONTEND\" --prefix-colors \"blue,green\" \"npm run backend\" \"npm run frontend\"",
    "backend": "bash -c 'source ~/.venv/bin/activate && cd backend && uvicorn main:app --reload --port 8000'",
    "frontend": "cd frontend && npm run dev"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
